{
  "manifest_version": 3,
  "name": "QuickLinks",
  "version": "1.0.0",
  "description": "Replaces the new tab page with a customizable grid of visual shortcuts (speed dial).",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
